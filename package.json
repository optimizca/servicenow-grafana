{
  "name": "servicenow-optimiz",
  "version": "1.8.2",
  "description": "ServiceNow Plugin Developed by Optimiz ca",
  "overrides": {
  "serialize-javascript": "7.0.3"
  },
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "e2e": "yarn exec cypress install && yarn exec grafana-e2e run",
    "e2e:update": "yarn exec cypress install && yarn exec grafana-e2e run --update-screenshots",
    "lint": "eslint --cache --ignore-path ./.gitignore --ext .jsx,.ts,.tsx .",
    "lint:fix": "yarn run lint --fix",
    "server": "docker-compose up --build",
    "sign": "npx --yes @grafana/sign-plugin@latest",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit"
  },
  "author": "Optimiz",
  "license": "Apache-2.0",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@grafana/eslint-config": "6.0.1",
    "@grafana/tsconfig": "^1.3.0-rc1",
    "@swc/core": "1.3.75",
    "@swc/helpers": "^0.5.19",
    "@swc/jest": "^0.2.26",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^18.19.130",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^6.7.3",
    "eslint-webpack-plugin": "^5.0.3",
    "fork-ts-checker-webpack-plugin": "^8.0.0",
    "glob": "^13.0.6",
    "identity-obj-proxy": "3.0.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "prettier": "^2.8.7",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "sass": "1.63.2",
    "sass-loader": "13.3.1",
    "style-loader": "3.3.3",
    "swc-loader": "^0.2.7",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "4.8.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "webpack-livereload-plugin": "^3.0.2"
  },
  "engines": {
    "node": ">=12"
  },
  "dependencies": {
    "@cypress/request": ">=3.0.0",
    "@emotion/css": "^11.1.3",
    "@grafana/data": "^11.5.0",
    "@grafana/runtime": "^11.5.0",
    "@grafana/ui": "^11.5.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/request": "^2.48.7",
    "collections": "^5.1.12",
    "js-yaml": "^4.1.1",
    "lodash": "^4.17.23",
    "log4js": ">=6.4.0",
    "memory-cache": "^0.2.0",
    "minimatch": "^10.2.4",
    "postcss": "^8.4.5",
    "qs": "^6.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.13.1",
    "react-select": "^5.10.0",
    "terser-webpack-plugin": "^5.3.16",
    "tslib": "2.5.3",
    "underscore": "^1.13.8"
  }
}
